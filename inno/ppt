    <style>
        :root {
            --primary: #ff8fb1;
            --primary-soft: #ffc2d1;
            --accent: #b28dff;
            --bg-light: #fff5f8;
            --text-dark: #4a4a4a;
            --white: #ffffff;
            --shadow: 0 10px 30px rgba(255, 143, 177, 0.15);
        }

        body, html {
            margin: 0;
            padding: 0;
            height: 100%;
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            background-color: var(--bg-light);
            color: var(--text-dark);
            overflow: hidden;
        }

        .slides {
            position: relative;
            width: 100%;
            height: 100%;
        }

        .slide {
            position: absolute;
            inset: 0;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            padding: 5% 10%;
            opacity: 0;
            visibility: hidden;
            transition: all 0.6s cubic-bezier(0.4, 0, 0.2, 1);
            background: var(--bg-light);
            background-image: 
                radial-gradient(circle at 10% 20%, rgba(255, 194, 209, 0.3) 0%, transparent 20%),
                radial-gradient(circle at 90% 80%, rgba(178, 141, 255, 0.2) 0%, transparent 25%);
        }

        .slide.active {
            opacity: 1;
            visibility: visible;
            z-index: 10;
        }

        h1 { font-size: 3.5em; color: var(--primary); margin: 0.2em 0; font-weight: 800; line-height: 1.1; }
        h2 { font-size: 2.2em; color: var(--accent); margin-bottom: 0.5em; font-weight: 700; }
        h3 { font-size: 1.5em; color: var(--primary); margin-bottom: 0.3em; }

        p, li { font-size: 1.15em; line-height: 1.5; max-width: 900px; margin: 0.4em auto; }

        .highlight-box {
            background: var(--white);
            padding: 1.5rem;
            border-radius: 20px;
            box-shadow: var(--shadow);
            border-left: 8px solid var(--primary);
            text-align: left;
            margin: 1em 0;
            width: 85%;
        }

        .team-grid { display: flex; justify-content: center; gap: 1.5rem; margin-top: 1.5rem; }
        .member {
            background: var(--white);
            padding: 0.6rem 1.2rem;
            border-radius: 50px;
            box-shadow: var(--shadow);
            font-weight: 600;
            color: var(--primary);
            border: 1px solid var(--primary-soft);
            font-size: 0.9em;
        }

        .grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 15px;
            width: 100%;
            max-width: 1100px;
            margin-top: 15px;
        }

        .card {
            background: var(--white);
            padding: 1.2rem;
            border-radius: 20px;
            box-shadow: var(--shadow);
            transition: transform 0.3s ease;
            display: flex;
            flex-direction: column;
            justify-content: center;
            border: 1px solid transparent;
        }
        .card:hover { border-color: var(--primary-soft); transform: translateY(-5px); }

        .nav-hints {
            position: absolute;
            bottom: 25px;
            left: 50%;
            transform: translateX(-50%);
            display: flex;
            gap: 15px;
            z-index: 100;
        }

        .nav-btn {
            background: var(--white);
            border: none;
            padding: 10px 20px;
            border-radius: 12px;
            cursor: pointer;
            box-shadow: var(--shadow);
            color: var(--primary);
            font-weight: bold;
            transition: 0.3s;
        }
        .nav-btn:hover { background: var(--primary); color: white; }

        .slide-number {
            position: absolute;
            bottom: 30px;
            right: 40px;
            font-weight: bold;
            color: var(--primary-soft);
        }

        a { color: var(--accent); text-decoration: none; font-weight: bold; }
        ul { text-align: left; display: inline-block; }
    </style>
</head>
